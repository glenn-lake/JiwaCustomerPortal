{
  "DetailedErrors": true,
  // ShowDiagnostics will show the diagnostics page in the Nav Menu
  "ShowDiagnostics": "false",
  "JiwaAPIURL": "http://localhost",
  /* 
  JiwaAPIKey is required for a small number of requests, these are:

  GET /CustomerWebPortal/Settings
  GET /SystemInfo
  GET /Queries/FX_Currency
  GET /Queries/ContactNameMultiples
  POST /Debtors/ContactNames/{ContactNameID}/PasswordReset
  POST /Debtors/ContactNames/{Token}/TokenisedPasswordChange

  All other requests use either debtor contact authentication, where they authenticate using their email address and a bcrypted (one way) password,
  or they use Jiwa authentication - staff members using their jiwa username and password.
  */
  "JiwaAPIKey": "DaPNd4BwDqZJHkngxzgBNG9KHrNIElrqfZh23xlb5kQ",
  "AllowCustomerLogin": true,
  "AllowStaffLogin": false,
  "IN_LogicalID": "{Default Logical ID for your Jiwa Instance}",
  "IN_PhysicalID": "{Default Physical ID for your Jiwa Instance}",
  "LogicalWarehouseDescription": "{Default Logical Warehouse Description for your Jiwa Instance}",
  "PhysicalWarehouseDescription": "{Default Physical Warehouse Description for your Jiwa Instance}",  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "MyHttpEndpoint": {
        "Url": "http://*:5010"
      }
    }
  }
}

