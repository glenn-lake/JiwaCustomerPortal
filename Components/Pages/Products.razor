    private void PreviousPage()
    {
        if (CurrentPage > 1)
        {
            CurrentPage--;
        }
    }

    private void NextPage()
    {
        if (CurrentPage < TotalPages)
        {
            CurrentPage++;
        }
    }

    private void HandleAPIException(Exception ex)
    {
        if (ex is WebServiceException webServiceException)
        {
            if (webServiceException.StatusCode == 401)
            {
                WebPortalUserSessionStateContainer.SetWebPortalUserSession(null);
                NavigationManager.NavigateTo($"User/SignIn?returnUrl={NavigationManager.Uri}");
                return;
            }

            statusMessage = webServiceException.ErrorMessage;
            return;
        }

        statusMessage = ex.Message;
    }

    private void AppendSessionNotice(string message)
    {
        if (string.IsNullOrWhiteSpace(message))
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(SessionNotice))
        {
            SessionNotice = message;
            return;
        }

        if (!SessionNotice.Contains(message, StringComparison.OrdinalIgnoreCase))
        {
            SessionNotice += " " + message;
        }
    }
